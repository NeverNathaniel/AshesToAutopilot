{
  "name": "ashes-to-autopilot",
  "version": "1.2.2",
  "description": "AshesToAutopilot — portable desktop app for pre-wipe device preparation and Autopilot readiness",
  "main": "app/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.ashestoautopilot.toolkit",
    "productName": "AshesToAutopilot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "app/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "Scripts",
        "to": "toolkit/Scripts"
      },
      {
        "from": "Start-PreWipeToolkit.ps1",
        "to": "toolkit/Start-PreWipeToolkit.ps1"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "requestExecutionLevel": "admin",
      "artifactName": "AshesToAutopilot-Portable-${version}.exe"
    }
  }
}
